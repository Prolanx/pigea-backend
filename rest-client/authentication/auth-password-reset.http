### Forgot Password and Reset Password Tests

@baseUrl = http://localhost:3000/auth
@email = test@example.com

################################################################################
### 1. Request Password Reset (Forgot Password)
POST {{baseUrl}}/forgot-password
Content-Type: application/json

{
  "email": "{{email}}"
}

# Expected Response (200):
# {
#   "status": "success",
#   "message": "If an account with that email exists, a password reset link has been sent",
#   "data": null
# }

################################################################################
### 2. Request Password Reset - Non-existent Email (Security: Same Response)
POST {{baseUrl}}/forgot-password
Content-Type: application/json

{
  "email": "nonexistent@example.com"
}

# Expected Response (200):
# Same success message even if account doesn't exist (security best practice)

################################################################################
### 3. Request Password Reset - Invalid Email Format
POST {{baseUrl}}/forgot-password
Content-Type: application/json

{
  "email": "invalid-email"
}

# Expected Response (400):
# Validation error for invalid email format

################################################################################
### 4. Reset Password with Code
# NOTE: Replace <RESET_CODE> with the 5-digit code from the email
POST {{baseUrl}}/reset-password
Content-Type: application/json

{
  "token": "<RESET_CODE>",
  "newPassword": "NewSecurePass123"
}

# Expected Response (200):
# {
#   "status": "success",
#   "message": "Password reset successful. Please login with your new password.",
#   "data": null
# }

################################################################################
### 5. Reset Password - Invalid Code Format
POST {{baseUrl}}/reset-password
Content-Type: application/json

{
  "token": "abc123",
  "newPassword": "NewSecurePass123"
}

# Expected Response (400):
# Validation error: Reset code must be numeric

################################################################################
### 6. Reset Password - Invalid Code
POST {{baseUrl}}/reset-password
Content-Type: application/json

{
  "token": "99999",
  "newPassword": "NewSecurePass123"
}

# Expected Response (400):
# {
#   "status": "error",
#   "message": "Invalid or expired password reset token",
#   "data": null
# }

################################################################################
### 7. Reset Password - Expired Code
# NOTE: Codes expire after 1 hour by default
POST {{baseUrl}}/reset-password
Content-Type: application/json

{
  "token": "<EXPIRED_CODE>",
  "newPassword": "NewSecurePass123"
}

# Expected Response (400):
# {
#   "status": "error",
#   "message": "Invalid or expired password reset token",
#   "data": null
# }

################################################################################
### 8. Reset Password - Weak Password
POST {{baseUrl}}/reset-password
Content-Type: application/json

{
  "token": "<RESET_CODE>",
  "newPassword": "123"
}

# Expected Response (400):
# Validation error: Password must be at least 8 characters

################################################################################
### 9. Login with New Password (After Reset)
POST {{baseUrl}}/login
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "NewSecurePass123"
}

# Expected Response (200):
# {
#   "status": "success",
#   "message": "Login successful",
#   "data": {
#     "accessToken": "...",
#     "refreshToken": "...",
#     "account": { ... }
#   }
# }

################################################################################
### Complete Password Reset Flow Test Scenario:
#
# 1. Request password reset (forgot-password)
# 2. Check email for 5-digit reset code
# 3. Copy code from email
# 4. Reset password using code
# 5. Login with new password
# 6. Old sessions invalidated (refresh token removed)
#
################################################################################
