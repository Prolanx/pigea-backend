###############################################
# DELETE PRODUCT
###############################################

### Delete Product - Success
DELETE {{apiUrl}}/{{productId}}
Authorization: Bearer {{accessToken}}

###

### Delete Product - Not Found
DELETE {{apiUrl}}/677a9b3c4f5e6d7a8b9c0d20
Authorization: Bearer {{accessToken}}

###

### Delete Product - Invalid ID Format (Validation Error)
DELETE {{apiUrl}}/invalid-id-format
Authorization: Bearer {{accessToken}}

###

### Delete Product - Unauthenticated (No Bearer Token)
DELETE {{apiUrl}}/{{productId}}

###

### Delete Product - Invalid Token
DELETE {{apiUrl}}/{{productId}}
Authorization: Bearer invalid-token-here

###

### Delete Product - Another Merchant's Product (Permission Denied - 403)
# Note: If the product exists but belongs to another merchant, you'll get a 403 error
# Replace the ID below with an actual product ID from another merchant's account to test
DELETE {{apiUrl}}/677a9b3c4f5e6d7a8b9c0d22
Authorization: Bearer {{accessToken}}
