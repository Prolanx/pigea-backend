###############################################
# PRODUCT SUCCESS SCENARIOS
###############################################

### Create Product - Success (All fields with category)
POST {{apiUrl}}
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "name": "iPhone 15 Pro Max",
  "description": "The latest flagship smartphone from Apple with advanced camera system and A17 Pro chip",
  "price": 1199.99,
  "inventory": 50,
  "thresholdType": "custom",
  "threshold": 10,
  "shippingType": "custom",
  "shippingCost": 25.00,
  "imageUrl": "https://images.unsplash.com/photo-1511707171634-5f897ff02aa9?w=600&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8MTJ8fE1vYmlsZSUyMFBob25lc3xlbnwwfHwwfHx8MA%3D%3D",
  "isActive": true,
  "categoryId": "{{categoryId}}"
}

###

### Create Product - Success (Required fields only)
POST {{apiUrl}}
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "name": "MacBook Pro 16-inch",
  "description": "Powerful laptop for professionals with M3 Pro chip and stunning Liquid Retina XDR display",
  "price": 2499.99,
  "inventory": 25,
  "thresholdType": "auto",
  "shippingType": "auto",
  "categoryId": "{{categoryId}}"
}

###

### Create Product - Success (Product with variants and attributes)
POST {{apiUrl}}
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "name": "Premium T-Shirt",
  "description": "A premium cotton t-shirt available in multiple colors and sizes.",
  "price": 29.99,
  "inventory": 100,
  "thresholdType": "custom",
  "threshold": 15,
  "shippingType": "custom",
  "shippingCost": 5.99,
  "imageUrl": "https://example.com/images/premium-tshirt.jpg",
  "categoryId": "{{categoryId}}",
  "attributes": [
    {
      "name": "Color",
      "values": ["Black", "White", "Navy"]
    },
    {
      "name": "Size",
      "values": ["S", "M", "L"]
    }
  ],
  "variants": [
    {
      "variant": "Black / M",
      "price": 29.99,
      "stock": 25,
      "media": ["https://example.com/images/tshirt-black-m.jpg"],
      "optionValues": { "Color": "Black", "Size": "M" }
    },
    {
      "variant": "White / L",
      "price": 29.99,
      "stock": 30,
      "media": ["https://example.com/images/tshirt-white-l.jpg"],
      "optionValues": { "Color": "White", "Size": "L" }
    }
  ]
}

###

### Update Product - Success (Update all fields)
PUT {{apiUrl}}/{{productId}}
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "name": "iPhone 15 Pro Max Gold Edition",
  "description": "The latest flagship smartphone from Apple with advanced camera system, A17 Pro chip, and titanium design",
  "price": 1099.99,
  "inventory": 75,
  "thresholdType": "custom",
  "threshold": 20,
  "shippingType": "custom",
  "shippingCost": 30.00,
  "isActive": false
}

###

### Update Product - Success (Update price only)
PUT {{apiUrl}}/{{productId}}
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "price": 3999.99
}

###

### Update Product - Success (Switch to auto threshold and auto shipping)
PUT {{apiUrl}}/{{productId}}
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "thresholdType": "auto",
  "shippingType": "auto"
}

###

### Update Product - Success (Switch to custom threshold and custom shipping)
PUT {{apiUrl}}/{{productId}}
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "thresholdType": "custom",
  "threshold": 15,
  "shippingType": "custom",
  "shippingCost": 18.00
}

###

### Update Product - Success (Add variants and attributes)
PUT {{apiUrl}}/{{productId}}
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "attributes": [
    {
      "name": "Color",
      "values": ["Black", "White"]
    },
    {
      "name": "Size",
      "values": ["S", "M", "L"]
    }
  ],
  "variants": [
    {
      "variant": "Black / M",
      "price": 1099.99,
      "stock": 20,
      "media": ["https://example.com/images/black-m.jpg"],
      "optionValues": { "Color": "Black", "Size": "M" }
    },
    {
      "variant": "White / L",
      "price": 1099.99,
      "stock": 15,
      "media": ["https://example.com/images/white-l.jpg"],
      "optionValues": { "Color": "White", "Size": "L" }
    }
  ]
}

###

### Update Product - Success (Remove category - set to null)
PUT {{apiUrl}}/{{productId}}
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "categoryId": null
}
