POST {{apiUrl}}/invoices
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "customerId": "{{invoiceCustomerId}}",
  "customerEmail": "{{invoiceCustomerEmail}}",
  "invoiceCategory": "service",
  "issueDate": "2026-02-01T00:00:00.000Z",
  "dueDate": "2026-05-28T00:00:00.000Z",
  "notes": "Initial invoice",
  "status": "{{invoiceStatus}}",
  "items": [
    { "name": "Service A", "itemCategory": "service", "quantity": 10, "unitPrice": 350.00 },
    { "name": "Service B", "itemCategory": "service", "quantity": 15, "unitPrice": 1150.00 },
    { "name": "Service C", "itemCategory": "service", "quantity": 10, "unitPrice": 350.00 } 
     ],
  "tax": 0,
  "discount": 0
}

